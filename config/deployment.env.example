# Copy this file to config/deployment.env and update values for your environment.

# Core identity
ORG_SLUG=example
ENVIRONMENT=dev
ACCOUNT_ID=111122223333

# Regions
PRIMARY_REGION=us-east-1
DEPLOY_REGIONS=us-east-1,us-east-2

# Naming and tagging
NAME_PREFIX=example-workspaces-platform-dev
PROJECT_NAME=example-workspaces-platform
OWNER_TAG=platform-team
DEPARTMENT_TAG=PLATFORM
COST_CENTER=shared-platform
DATA_CLASS=Internal
CRITICALITY=Medium
COMPLIANCE=Internal

# Backend
BACKEND_BUCKET=example-workspaces-terraform-state
LOCK_TABLE=example-workspaces-platform-dev-terraform-locks
KMS_ALIAS=alias/example-workspaces-platform-dev-terraform-state-01

# WorkSpaces common settings
DIRECTORY_NAME=example.local
DIRECTORY_ID=d-0000000000
POOL_DIRECTORY_ID=wsd-00000000

WORKSPACES_SUBNET_1_CIDR=10.164.98.128/25
WORKSPACES_SUBNET_1_AZ=us-east-1b
WORKSPACES_SUBNET_1_AZ_ID=use1-az2
WORKSPACES_SUBNET_2_CIDR=10.164.99.0/25
WORKSPACES_SUBNET_2_AZ=us-east-1c
WORKSPACES_SUBNET_2_AZ_ID=use1-az4

TRUSTED_CIDRS=10.164.0.0/16
WORKSPACES_RUNNING_MODE=AUTO_STOP
WORKSPACES_AUTO_STOP_TIMEOUT=60
WORKSPACES_CREATE_TIMEOUT=120m

# Bundle defaults
STANDARD_BUNDLE=wsb-00000000
SOC_BUNDLE=wsb-00000001
DEV_BUNDLE=wsb-00000002

# WorkSpaces pools
POOL_VPC_ID=vpc-00000000000000000
POOL_SUBNET_IDS=subnet-00000000000000000,subnet-00000000000000001
SAML_XML_SECRET_NAME=REPLACE_WITH_SAML_XML_SECRET

# Optional behavior
# Set to true to delete non-selected WorkSpaces platform region folders.
PRUNE_REGIONS=false
